# KRIPTONSHARE - Archivos ignorados por Git
# Este archivo previene que archivos sensibles, temporales y generados
# sean subidos al repositorio público.

# ===========================================
# SECRETOS Y CONFIGURACIÓN LOCAL
# ===========================================
.env
.env.local
.env.development
.env.production
*.env.*
local.properties
android/local.properties
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
secrets/
keys/
*.keystore
*.jks
key.properties

# ===========================================
# FLUTTER / DART
# ===========================================
.dart_tool/
.pub/
.pub-cache/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
flutter_*.png
linked_*.ds
unlinked.ds
unlinked_spec.ds
.dart_tool/package_config.json

# ===========================================
# ANDROID
# ===========================================
android/.gradle/
android/captures/
android/gradlew
android/gradlew.bat
android/local.properties
android/key.properties
android/app/debug
android/app/profile
android/app/release
android/**/*.iml
android/.idea/
android/build/
android/app/*.keystore
android/app/*.jks
*.apk
*.aab

